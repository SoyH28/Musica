---
const { titulo, artista, imagen } = Astro.props;
---
<div class="music-card-inner">
  <div class="image-container">
    <img src={imagen} alt={titulo} loading="lazy" />
  </div>
  <div class="info">
    <p class="song-title">{titulo}</p>
    <p class="song-artist">{artista}</p>
  </div>
</div>

<style>
  .music-card-inner { pointer-events: none; }
  .image-container {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 8px;
    background: #282828;
  }
  img { width: 100%; height: 100%; object-fit: cover; }
  .song-title {
    font-weight: 600;
    font-size: 0.85rem;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .song-artist {
    font-size: 0.75rem;
    color: #b3b3b3;
    margin: 2px 0 0 0;
  }
</style>